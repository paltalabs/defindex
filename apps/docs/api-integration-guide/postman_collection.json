        {
          "name": "Generate Api Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse the JSON response",
                  "const response = pm.response.json();",
                  "",
                  "// Check if the response exists and has a key property",
                  "if (response && response.key) {",
                  "    // Set the api_key environment variable with the key value",
                  "    pm.environment.set(\"api_key\", response.key);",
                  "    ",
                  "    // Optional: Log success message to console",
                  "    console.log(\"API key successfully set in environment variables\");",
                  "    console.log(\"Key:\", response.key);",
                  "    console.log(\"ID:\", response.id);",
                  "} else if (response && Array.isArray(response) && response.length > 0) {",
                  "    // Fallback: Handle array response (your original logic)",
                  "    const firstItem = response[0];",
                  "    if (firstItem && firstItem.key) {",
                  "        pm.environment.set(\"api_key\", firstItem.key);",
                  "        console.log(\"API key successfully set from array response\");",
                  "        console.log(\"Key:\", firstItem.key);",
                  "    } else {",
                  "        console.error(\"Key not found in the first array element\");",
                  "    }",
                  "} else {",
                  "    // Log error if response doesn't have expected structure",
                  "    console.error(\"Response doesn't contain expected key property\");",
                  "    console.log(\"Response structure:\", response);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {}
              }
