        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse the JSON response",
                  "const response = pm.response.json();",
                  "",
                  "// Check if the response contains an access_token",
                  "if (response && response.access_token) {",
                  "    // Set the jwt_token environment variable with the access_token value",
                  "    pm.environment.set(\"jwt_token\", response.access_token);",
                  "    ",
                  "    // Optional: Log success message to console",
                  "    console.log(\"JWT token successfully set in environment variables\");",
                  "    console.log(\"Token:\", response.access_token);",
                  "} else {",
                  "    // Log error if access_token is not found",
                  "    console.error(\"Access token not found in response\");",
                  "}",
                  "",
                  "// Optional: Also save the refresh_token if needed",
                  "if (response && response.refresh_token) {",
                  "    pm.environment.set(\"refresh_token\", response.refresh_token);",
                  "    console.log(\"Refresh token also saved\");",
                  "}",
                  "",
                  "// Optional: Add test to verify the response",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has access_token\", function () {",
                  "    pm.expect(response).to.have.property('access_token');",
                  "});",
                  "",
                  "pm.test(\"Response has refresh_token\", function () {",
                  "    pm.expect(response).to.have.property('refresh_token');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
